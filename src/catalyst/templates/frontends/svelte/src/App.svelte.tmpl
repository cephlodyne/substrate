<script lang="ts">
  import { onMount } from "svelte";
  import { createClient } from "@connectrpc/connect";
  import { createConnectTransport } from "@connectrpc/connect-web";
  import { PingService } from "./gen/ping/v1/ping_pb";

  const transport = createConnectTransport({ baseUrl: "" });
  const client = createClient(PingService, transport);

  let statusMessage = "Pinging Go backend...";

  onMount(async () => {
    try {
      const response = await client.ping({ name: "Strata Crowd" });
      statusMessage = response.message;
    } catch (error) {
      statusMessage = "API unreachable. Check terminal logs.";
      console.error(error);
    }
  });
</script>

<main>
  <h1>CEPHLODYNE_APP_NAME</h1>
  <div class="card">
    <h2>Backend Status:</h2>
    <p><strong>{statusMessage}</strong></p>
  </div>
</main>

