-include .env
export

CONTRACTS_DIR ?= {{CONTRACTS_DIR}}

.PHONY: install-deps generate build-frontend run dev

install-deps:
	@echo "Installing frontend dependencies for code generation..."
	cd frontend && pnpm install

generate: install-deps
	@echo "Generating code from central contracts..."
	buf generate $${CONTRACTS_DIR}/proto --template buf.gen.yaml

build-frontend: generate
	@echo "Building frontend locally..."
	cd frontend && pnpm build

run: build-frontend
	@echo "Tidying and vendoring Go dependencies..."
	go mod tidy
	go mod vendor
	@echo "Ensuring frontend dist directory exists for go:embed..."
	mkdir -p frontend/dist && echo "<!-- dev server placeholder -->" > frontend/dist/index.html
	@echo "Starting production-like embedded server on port $${API_PORT}..."
	go run ./cmd/server/main.go

dev: generate
	@echo "Tidying and vendoring Go dependencies..."
	go mod tidy
	go mod vendor
	@echo "Ensuring frontend dist directory exists for go:embed..."
	mkdir -p frontend/dist && echo "<!-- dev server placeholder -->" > frontend/dist/index.html
	@echo "Starting rapid local development environment..."
	@echo "Go API running on http://localhost:$${API_PORT}"
	@bash -c '\
		go run ./cmd/server/main.go & \
		GO_PID=$$!; \
		cd frontend && pnpm dev & \
		VITE_PID=$$!; \
		trap "kill -9 $$GO_PID $$VITE_PID 2>/dev/null" SIGINT SIGTERM EXIT; \
		wait \
	'
